# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly declare text files
*.php text
*.py text
*.md text
*.json text
*.yml text
*.yaml text
*.blade.php text
*.js text
*.css text
*.html text
*.sh text

# Denote binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary

